---
const plans = [
  {
    name: "ライトプラン",
    price: "95,000",
    unit: "月額（税抜）",
    hours: "月10時間",
    description: "壁打ち・レビュー中心のプラン",
    features: [
      "インフラ・CI/CD のレビュー",
      "技術選定・設計の壁打ち",
      "改善提案・ドキュメント作成",
      "Slack / Meet での相談対応",
      "月10時間まで",
    ],
    highlighted: false,
  },
  {
    name: "スタンダードプラン",
    price: "285,000",
    unit: "月額（税抜）",
    hours: "月30時間",
    description: "相談+実作業のプラン",
    features: [
      "ライトプランの全内容",
      "インフラ設計・構築",
      "CI/CD パイプライン構築",
      "Terraform によるIaC化",
      "月30時間まで",
    ],
    highlighted: true,
  },
  {
    name: "カスタムプラン",
    price: null,
    unit: "",
    hours: "",
    description: "時間・内容を柔軟に調整",
    features: [
      "スタンダードプランの全内容",
      "月30時間以上の稼働にも対応",
      "チーム体制やスケジュールに合わせて調整",
    ],
    highlighted: false,
  },
];
---

<section id="pricing" class="py-24 px-6 bg-bg-card/30">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-4">Pricing</h2>
    <p class="text-text-muted text-center mb-4">料金プラン</p>

    <div class="grid md:grid-cols-3 gap-8 mb-8">
      {plans.map((plan) => (
        <div
          class:list={[
            "p-8 rounded-xl border transition-colors flex flex-col",
            plan.highlighted
              ? "bg-bg-card border-primary shadow-lg shadow-primary/10"
              : "bg-bg-card border-border",
          ]}
        >
          <div class="min-h-6">
            {plan.highlighted && (
              <span class="inline-block text-xs font-semibold text-accent bg-accent/10 px-3 py-1 rounded-full">
                おすすめ
              </span>
            )}
          </div>
          <h3 class="text-xl font-bold mb-1 mt-2">{plan.name}</h3>
          <p class="text-text-muted text-sm mb-4">{plan.description}</p>
          <div class="mb-2 whitespace-nowrap">
            {plan.price ? (
              <span class="text-3xl font-bold">¥{plan.price}</span>
            ) : (
              <span class="text-3xl font-bold">要相談</span>
            )}
            {plan.unit && <span class="text-text-muted text-sm ml-2">{plan.unit}</span>}
          </div>
          <div class="h-8 flex items-center">
            {plan.hours && <p class="text-accent text-sm font-mono">{plan.hours}</p>}
          </div>
          <ul class="space-y-3">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-2 text-sm text-text-muted">
                <span class="text-primary mt-0.5">&#10003;</span>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="text-text-muted text-xs text-center space-y-1">
      <p>※ 時給 ¥9,500（税抜）× 実稼働時間でのご請求です（各プランの時間が上限）</p>
      <p>※ 超過分は事前相談の上、¥12,000/h で追加可能</p>
    </div>
  </div>
</section>
